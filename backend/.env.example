# ============== App ==============
NODE_ENV=development
PORT=3000

# ============== Base de datos ==============
# El backend detecta automáticamente el dialect por el prefijo de la URL.
#
# DESARROLLO LOCAL (MySQL):
#   DATABASE_URL=mysql://root:@localhost:3306/quickrescue
#
# DESARROLLO LOCAL (PostgreSQL):
#   DATABASE_URL=postgres://postgres:postgres@localhost:5432/quickrescue
#
# PRODUCCIÓN (Render Postgres):
#   DATABASE_URL=postgres://user:pass@dpg-XXX.oregon-postgres.render.com/quickrescue
#
# PRODUCCIÓN (Aiven MySQL):
#   DATABASE_URL=mysql://avnadmin:PASS@HOST.aivencloud.com:PORT/defaultdb?ssl-mode=REQUIRED
DATABASE_URL=mysql://root:@localhost:3306/quickrescue

# ============== JWT ==============
# Generar con: openssl rand -hex 32
JWT_SECRET=cambia_esto_con_un_secreto_largo_y_aleatorio
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=30d

# ============== Email (Resend) ==============
# Cuenta gratis en https://resend.com — 100 emails/día sin tarjeta
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxx
EMAIL_FROM="Quick Rescue <onboarding@resend.dev>"

# ============== CORS ==============
# Lista de orígenes separados por coma. Para desarrollo local con Vite:
CORS_ORIGINS=http://localhost:5173

# ============== Maps ==============
# Para construir links a Google Maps en los emails de notificación de escaneos
GOOGLE_MAPS_BASE_URL=https://www.google.com/maps?q=
