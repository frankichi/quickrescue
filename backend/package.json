{
  "name": "quick-rescue-backend",
  "version": "1.1.0",
  "description": "API REST de Quick Rescue (Node + Express + TypeScript + Sequelize)",
  "main": "dist/main.js",
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only src/main.ts",
    "build": "tsc && node -e \"require('fs').cpSync('src/emails','dist/emails',{recursive:true})\"",
    "start": "node dist/main.js",
    "lint": "eslint 'src/**/*.ts'",
    "test": "echo \"TODO: añadir tests con Jest + Supertest\" && exit 0"
  },
  "dependencies": {
    "bcrypt": "^5.1.1",
    "cloudinary": "^2.0.0",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "express-validator": "^7.1.0",
    "helmet": "^7.1.0",
    "jsonwebtoken": "^9.0.2",
    "morgan": "^1.10.0",
    "multer": "^1.4.5-lts.1",
    "mysql2": "^3.10.0",
    "pg": "^8.12.0",
    "pg-hstore": "^2.3.4",
    "resend": "^4.0.0",
    "sequelize": "^6.37.3"
  },
  "devDependencies": {
    "@types/bcrypt": "^5.0.2",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.6",
    "@types/morgan": "^1.9.9",
    "@types/multer": "^1.4.11",
    "@types/node": "^20.12.12",
    "@types/pg": "^8.11.6",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.4.5"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
